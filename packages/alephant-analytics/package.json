{
  "name": "@alephantai/n8n-nodes-alephant-analytics",
  "version": "0.1.10",
  "description": "n8n node for Alephant AI usage analytics and request log lookups",
  "license": "MIT",
  "homepage": "https://alephant.io",
  "author": {
    "name": "Alephant",
    "email": "dev@alephant.io",
    "url": "https://alephant.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlephantAI/alephant-n8n.git",
    "directory": "packages/alephant-analytics"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "alephant",
    "analytics",
    "ai",
    "finops"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json && node ../../scripts/copy-package-assets.cjs dist AlephantUsage",
    "lint": "npm --prefix ../.. run lint",
    "test": "npm --prefix ../.. run test",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AlephantVirtualKeyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/AlephantUsage/AlephantUsage.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "n8n-workflow": "*",
    "typescript": "^5.6.3"
  }
}
