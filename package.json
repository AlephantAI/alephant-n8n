{
  "name": "@alephantai/n8n-nodes-alephant",
  "version": "0.1.14",
  "description": "n8n node for Alephant AI Gateway cost control and analytics",
  "license": "MIT",
  "homepage": "https://alephant.io",
  "author": {
    "name": "Alephant",
    "email": "dev@alephant.io",
    "url": "https://alephant.io"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AlephantAI/alephant-n8n.git"
  },
  "keywords": [
    "n8n-community-node-package",
    "n8n",
    "alephant",
    "ai",
    "finops",
    "byok"
  ],
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "npm run clean && tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "node scripts/copy-assets.cjs",
    "dev": "n8n-node dev",
    "lint": "eslint \"{credentials,nodes,shared,test}/**/*.ts\"",
    "test": "jest --runInBand",
    "prepublishOnly": "npm run lint && npm run test && npm run build"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ],
  "n8n": {
    "n8nNodesApiVersion": 1,
    "credentials": [
      "dist/credentials/AlephantVirtualKeyApi.credentials.js"
    ],
    "nodes": [
      "dist/nodes/Alephant/Alephant.node.js"
    ]
  },
  "peerDependencies": {
    "n8n-workflow": "*"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "^20.12.12",
    "@n8n/node-cli": "^0.29.1",
    "eslint": "^9.31.0",
    "jest": "^29.7.0",
    "n8n-workflow": "*",
    "ts-jest": "^29.2.5",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.35.0"
  }
}
